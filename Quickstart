library(hybridEHR)

# 1) COVID CT research dataset
res <- generate_hybrid_ehr(
  n_patients = 1000,
  n_sites = 4,
  covid_focused = TRUE,
  include_ct_links = TRUE,
  output_dir = "covid_ct_research_dataset",
  seed = 42
)

# Access in-memory tables
str(res$dataset$tables$patients)
names(res$dataset$research)

